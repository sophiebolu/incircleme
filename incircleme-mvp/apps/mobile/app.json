{
  "expo": {
    "name": "IncircleMe",
    "slug": "incircleme",
    "owner": "incircleme",
    "scheme": "incircleme",
    "version": "0.0.1",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/f3c64a37-b208-4456-a699-c375aab55dd3"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.incircleme.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.incircleme.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Fraunces_500Medium.ttf",
            "./assets/fonts/Fraunces_500Medium_Italic.ttf",
            "./assets/fonts/Fraunces_600SemiBold.ttf",
            "./assets/fonts/Inter_400Regular.ttf",
            "./assets/fonts/Inter_500Medium.ttf",
            "./assets/fonts/Inter_600SemiBold.ttf",
            "./assets/fonts/Inter_800ExtraBold.ttf"
          ]
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.incircleme.app",
          "enableGooglePay": false
        }
      ],
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.PLACEHOLDER_REPLACE_FOR_IOS"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f3c64a37-b208-4456-a699-c375aab55dd3"
      }
    }
  }
}
